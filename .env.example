# Google OAuth2 credentials for Google Drive integration
# Create OAuth Client IDs at https://console.cloud.google.com/apis/credentials
# Desktop type: requires both CLIENT_ID and CLIENT_SECRET
# Android type: only needs CLIENT_ID (PKCE handles security)
SYNABIT_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
SYNABIT_GOOGLE_CLIENT_SECRET=your-desktop-client-secret-here
