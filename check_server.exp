#!/usr/bin/expect -f
set timeout -1
set pass ")r5SSq({Qrjb,Z\[%"
set host "45.76.153.98"
set user "root"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$pass\r"
expect "# "

send "ps aux | grep synabit\r"
expect "# "

send "tail -n 10 sync-server/server.log\r"
expect "# "

send "exit\r"
expect eof
